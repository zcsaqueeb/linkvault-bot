# ── Required ──────────────────────────────────────────────────────────────────
API_ID=
API_HASH=
BOT_TOKEN=

# ── Channels ──────────────────────────────────────────────────────────────────
LOG_CHANNEL=
DB_CHANNEL=

# Force users to join a channel before using bot (0 = disabled)
FORCE_SUB_CHANNEL=0

# ── Admins ────────────────────────────────────────────────────────────────────
ADMINS=

# ── Bot identity ──────────────────────────────────────────────────────────────
BOT_NAME=File-to-Link Bot
BOT_USERNAME=

# ── Optional web streaming ────────────────────────────────────────────────────
WEB_SERVER=False
URL=
STREAM_MODE=True
PORT=8080

# ── MongoDB (optional, leave blank for in-memory) ─────────────────────────────
MONGO_URI=